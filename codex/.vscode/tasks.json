{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "uv: 同步依赖 (Sync)",
            "type": "shell",
            "command": "uv sync",
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "uv: 运行当前文件 (Run)",
            "type": "shell",
            "command": "uv run python ${file}",
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "focus": true,
                "panel": "new"
            }
        },
        {
            "label": "uv: 运行测试 (Pytest)",
            "type": "shell",
            "command": "uv run pytest",
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "uv: Ruff 全局检查与修复",
            "type": "shell",
            "command": "uv run ruff check . --fix",
            "group": "none",
            "presentation": {
                "reveal": "silent"
            }
        }
    ]
}
